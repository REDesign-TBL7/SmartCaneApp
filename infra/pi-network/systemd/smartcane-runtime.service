[Unit]
Description=SmartCane Pi Runtime
After=network.target
Wants=network.target

[Service]
Type=simple
WorkingDirectory=__SMARTCANE_REPO_ROOT__/pi
ExecStart=__SMARTCANE_REPO_ROOT__/pi/.venv/bin/python __SMARTCANE_REPO_ROOT__/pi/src/main.py
ExecReload=__SMARTCANE_REPO_ROOT__/pi/.venv/bin/python -c "import os, signal; os.kill(int(open('/run/smartcane-runtime.pid').read()), signal.SIGHUP)"
Restart=always
RestartSec=5
User=root
Environment=PYTHONUNBUFFERED=1
Environment=SMARTCANE_LOG_LEVEL=INFO
WatchdogSec=300
TimeoutStartSec=300
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
